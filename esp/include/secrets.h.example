// Copy this file to include/secrets.h and fill in real values.
// The include/secrets.h path is gitignored.
#pragma once

#define WIFI_SSID       "your-wifi-ssid"
#define WIFI_PASSWORD   "your-wifi-password"

// OTA password: required. The Pi (or your laptop) needs the same string
// passed via --auth (or GARRA_OTA_PASSWORD env var per platformio.ini).
#define OTA_PASSWORD    "change-me-per-cabinet"

// mDNS hostname the OTA stack advertises. Must be unique per cabinet on
// the LAN. Pi-side uploads target "<hostname>.local".
#define OTA_HOSTNAME    "garra-chute"
