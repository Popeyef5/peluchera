# central/.env — copy to .env and fill in. Never commit the real thing.
#
# docker compose passes this to BOTH the backend and the Next build, which is why
# NEXT_PUBLIC_* live here too. Anything NEXT_PUBLIC_* is BAKED INTO THE JS BUNDLE
# at build time: changing one only takes effect after a rebuild (update.sh always
# rebuilds, so that's handled — but it's why they can never be runtime toggles).
#
# See DEPLOY.md for the pre-deploy checklist.

# ─── Mode ────────────────────────────────────────────────────────────────
# FREE_PLAY: everyone logs in for real (wallet / email / social — real account,
# real inventory, real payout address) but nobody pays. PLAY goes straight to the
# queue. Wins, boosters, cards, resells are all real; only the payment is skipped
# and withdrawals are simulated (no USDC leaves the treasury for a free play).
# Both paid rails refuse while this is on.
#
# Switch monetization on later: FREE_PLAY=false + restart the backend. NO frontend
# rebuild needed — the client is told at login.
FREE_PLAY=true

# BYPASS_PAYMENT is a DIFFERENT thing: demo mode, NO wallet at all, synthetic
# guest addresses. Nobody can log in as themselves. Dev + the sim use it.
# Leave this false in prod — FREE_PLAY is what you want.
BYPASS_PAYMENT=false
NEXT_PUBLIC_BYPASS_PAYMENT=false

# ─── Database ────────────────────────────────────────────────────────────
# Prod = Supabase ("Claws"). There is NO db service in docker-compose.yml.
#
# Use the SESSION pooler (port 5432). NOT the direct host — it is IPv6-only and
# an IPv4 VPS cannot reach it. NOT the transaction pooler (6543) — that's
# PgBouncer, which breaks the prepared statements SQLAlchemy/psycopg rely on.
# Password: Supabase dashboard -> Project Settings -> Database.
DATABASE_URL="postgresql+psycopg://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres?sslmode=require"

# ─── Money ───────────────────────────────────────────────────────────────
# Treasury: receives ticket payments, and pays out winnings. The address MUST be
# byte-identical in both vars or every crypto payment silently fails verification.
TREASURY_ADDRESS=0x...
NEXT_PUBLIC_TREASURY_ADDRESS=0x...
# Signs payouts from the treasury. Needs ETH for gas (+ USDC to pay winners).
# Falls back to CLAW_PRIVATE_KEY if unset.
TREASURY_PRIVATE_KEY=0x...

# Ticket price. These two must agree.
TICKET_PRICE_CENTS=1000
NEXT_PUBLIC_TICKET_PRICE_CENTS=1000

# USDC (Base Sepolia default).
USDC_TOKEN_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Card money is reversible; USDC payouts are not. Winnings from a card-funded
# ticket aren't withdrawable until this many days after the charge.
CHARGEBACK_HOLD_DAYS=7

# ─── Card rail (Stripe) ──────────────────────────────────────────────────
# Not needed while FREE_PLAY=true — the card option auto-hides without them.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Login (Reown / WalletConnect) ───────────────────────────────────────
# Required for real login. Email + Google/Apple/X must ALSO be enabled for this
# project in the Reown Cloud dashboard, and its configured domain must match the
# site's — a mismatch silently kills the social buttons.
NEXT_PUBLIC_PROJECT_ID=

# ─── Chain ───────────────────────────────────────────────────────────────
INFURA_API_KEY=
BASE_RPC_HTTP="https://base-sepolia.infura.io/v3/${INFURA_API_KEY}"
BASE_RPC_WS="wss://base-sepolia.infura.io/ws/v3/${INFURA_API_KEY}"
CHAIN_ID=84532
# The escrow contract is RETIRED (pay/win/balance/withdraw are all off-chain).
# Kept only because dead code still imports it.
CLAW_CONTRACT_ADDRESS=0x...
CLAW_PRIVATE_KEY=0x...

# ─── Cabinet ─────────────────────────────────────────────────────────────
PI_SERVER_URL=http://<pi-host>:5000

# ─── Admin panel (Supabase auth — unrelated to the DB) ───────────────────
# Without these the admin router refuses to mount and /admin 401s. The game
# still runs fine.
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
SUPABASE_JWT_SECRET=

# ─── Ops ─────────────────────────────────────────────────────────────────
DOMAIN_NAME=
EMAIL=
CERTBOT_ETC_VOL=claw_certbot_etc
CERTBOT_WWW_VOL=claw_certbot_www
COMPOSE_DIR=~/peluchera/central
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_CHAT_INFO=

# ─── Analytics (optional) ────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_UMAMI_SRC=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
